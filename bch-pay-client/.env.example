# BCHPay Environment Configuration
# Copiar este archivo a .env y personalizar

# Red de Bitcoin Cash
BCH_NETWORK=testnet  # o 'mainnet' para producción

# Ruta de almacenamiento (opcional)
# BCH_STORAGE_PATH=~/.bch_pay.json

# API REST
BCHPAY_HOST=0.0.0.0
BCHPAY_PORT=8000

# Discord Bot (opcional)
# DISCORD_BOT_TOKEN=your-discord-bot-token-here
# BOT_PREFIX=!

# Telegram Bot (opcional)
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Nodo BCH para verificación real (opcional)
# BCH_NODE_URL=https://jsonrcp.bchd.fountainhead.cash  # Ejemplo
# BCH_EXPLORER_URL=https://explorer.bitcoin.com/bch

# Modo debug
# DEBUG=true